# ── TTS ──────────────────────────────────────────────────────────────────────
# Backend selectable PER LANGUAGE:
#   "kokoro" — local, offline, no key needed (EN af_heart / ZH zf_xiaoxiao)
#   "edge"   — Microsoft cloud, FREE, no API key. Taiwan-accented Mandarin
#              (zh-TW-HsiaoChenNeural) + native word timestamps.
#   "fish"   — Fish Audio cloud, custom voices, needs FISH_API_KEY
# Cloud backends fall back to kokoro automatically if there is no internet.
TTS_BACKEND_EN=kokoro
TTS_BACKEND_ZH=edge

# Fish Audio credentials (only needed when a backend above is "fish").
# FISH_REF_ID picks the voice — browse https://fish.audio for reference ids.
FISH_API_KEY=your_fish_audio_api_key_here
FISH_REF_ID=e855dc04a51f48549b484e41c4d4d4cc

# Voice overrides:
# EDGE_VOICE_ZH=zh-TW-HsiaoYuNeural   # Taiwan voices: HsiaoChen (F), HsiaoYu (F), YunJhe (M)
# EDGE_VOICE_EN=en-US-AvaNeural
# Kokoro zh voices: zf_xiaobei/xiaoni/xiaoxiao/xiaoyi (F), zm_yunjian/yunxi/yunxia/yunyang (M)
# KOKORO_VOICE_ZH=zf_xiaoxiao
# KOKORO_VOICE_EN=af_heart

# Speaking speed per language (1.0 normal, 0.85 = 15% slower — Mandarin TTS
# tends to rush). Works on all backends; lip-sync adapts automatically.
# TTS_SPEED_EN=1.0
# TTS_SPEED_ZH=0.85

# ── LLM / RAG ─────────────────────────────────────────────────────────────────
# LLM API URL (default: localhost:5003)
LLM_API_URL=http://localhost:5003

# Ground answers in the ChromaDB knowledge base (llm/knowledge/)
USE_RAG=true

# Demo mode: force very short answers (1 sentence, zh ≤30 chars) so the avatar
# starts speaking sooner — useful for videos/live demos. Set false for normal use.
BRIEF_ANSWERS=false

# ── Features ─────────────────────────────────────────────────────────────────
# Vision mode: the 👁 button lets the avatar observe the user via webcam
# (SmolVLM2-256M, in-process, every 5s). Set to false to disable the feature.
VISION_ENABLED=true

# Public access: start.sh launches a Cloudflare tunnel so the avatar is reachable
# from ANY network (public https URL printed at the end). Set to false for
# LAN-only / offline use. Requires bin/cloudflared (downloaded by setup.sh).
ENABLE_TUNNEL=true

# Robot integration: forward [ROBOT: ...] commands to the ROS2 container.
# Set ROBOT_ENABLED=false to run avatar-only mode (no ROS2, no robot commands).
ROBOT_CONTAINER=robotic_agent_system
ROBOT_ENABLED=false
